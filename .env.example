# ── Telegram bot (required) ──────────────────────────────────────────────────
# Create a new bot via @BotFather on Telegram → /newbot
POLYMARKET_BOT_TOKEN=
# Your personal Telegram user ID (the first/owner admin). Get it from @userinfobot.
TELEGRAM_ADMIN_ID=

# ── Master encryption key (required) ─────────────────────────────────────────
# CROWN JEWEL: decrypts every user's private key in config/user_keys.enc.json.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Protect hardest — chmod 600 this file; at go-live move into systemd LoadCredential or a KMS.
POLYMARKET_SECRETS_KEY=

# ── Per-user Polymarket credentials — NOT set here ───────────────────────────
# Private keys / funder addresses are stored PER USER, Fernet-encrypted, in
# config/user_keys.enc.json via the Telegram onboarding flow (/wallet_setup).
# They are never read from .env at runtime. (Legacy POLYMARKET_PRIVATE_KEY /
# POLYMARKET_FUNDER_ADDRESS were a one-time admin bootstrap and have been removed.)

# ── Relayer / builder creds (required for live gasless ops) ──────────────────
# Operator-level (one shared builder account), NOT per-user. From Polymarket.
BUILDER_API_KEY=
BUILDER_SECRET=
BUILDER_PASS_PHRASE=

# ── Risk / scheduling (optional — defaults shown) ────────────────────────────
MAX_LIVE_TRADE_USD=50
AUTO_SCAN_INTERVAL=14400     # paper/live scan cadence in seconds (4h); 0 disables
AUTO_RESOLVE_INTERVAL=3600   # auto-resolve cadence in seconds (1h); 0 disables

# ── Infra (optional) ─────────────────────────────────────────────────────────
# Persistent data dir (users.json, encrypted store, logs). Defaults to repo root.
RAILWAY_VOLUME_MOUNT_PATH=/opt/polymarket-bot/data
# Python interpreter for spawned scan/resolve subprocesses (defaults to venv).
# PYTHON_BIN=

# ── Data sources (optional) ──────────────────────────────────────────────────
# pmxt cross-venue scanner (legacy gap logger only). https://pmxt.dev
# PMXT_API_KEY=pmxt_...
# ECMWF direct API (optional tertiary weather source, premium)
# ECMWF_API_KEY=...
